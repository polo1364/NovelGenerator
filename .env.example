# 複製此檔為 .env 並填入你的 DeepSeek 金鑰
# 取得金鑰： https://platform.deepseek.com/api_keys

DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 選用：自訂連接埠（預設 3000）
# PORT=3000

# 選用：自訂 DeepSeek 端點（一般不需更動）
# DEEPSEEK_URL=https://api.deepseek.com/chat/completions

# 選用：Edge TTS 代理（未設定時使用內建預設代理；設為 off 則僅直連 WebSocket）
# TTS_PROXY_URL=https://your-tts-proxy.example.com
